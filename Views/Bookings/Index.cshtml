@{
    ViewData["Title"] = "Booking Requests";
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div>
        <h1 class="text-3xl font-bold text-slate-800">Booking Requests</h1>
        <p class="text-slate-500">Approve or reject resident facility bookings.</p>
    </div>

    <div class="space-y-4">
        <!-- Request 1 Pending -->
        <div class="bg-white border border-slate-100 p-5 rounded-2xl flex flex-col md:flex-row items-center justify-between shadow-sm gap-4">
            <div class="flex items-center gap-4 w-full md:w-auto">
                <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center flex-shrink-0">
                    <i data-lucide="calendar" class="w-5 h-5"></i>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Community Hall</h3>
                    <p class="text-sm text-slate-500">
                        Sun Mar 15 2026 • <span class="font-semibold">Jane Smith</span> (A-102)
                    </p>
                    <p class="text-xs text-slate-600 font-medium mt-1">
                        1 Days • Total: ₹2000
                    </p>
                    <p class="text-xs text-slate-400">"Birthday Party"</p>
                </div>
            </div>

            <div class="flex gap-2 w-full md:w-auto justify-end">
                <button class="px-4 py-2 bg-green-100 text-green-700 rounded-lg text-sm font-bold hover:bg-green-200 transition">
                    Approve
                </button>
                <button class="px-4 py-2 bg-red-100 text-red-700 rounded-lg text-sm font-bold hover:bg-red-200 transition">
                    Reject
                </button>
            </div>
        </div>

        <!-- Request 2 Approved -->
        <div class="bg-white border border-slate-100 p-5 rounded-2xl flex flex-col md:flex-row items-center justify-between shadow-sm gap-4">
            <div class="flex items-center gap-4 w-full md:w-auto">
                <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center flex-shrink-0">
                    <i data-lucide="calendar" class="w-5 h-5"></i>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Swimming Pool</h3>
                    <p class="text-sm text-slate-500">
                        Sat Mar 21 2026 • <span class="font-semibold">John Doe</span> (B-205)
                    </p>
                    <p class="text-xs text-slate-600 font-medium mt-1">
                        1 Days • Total: ₹500
                    </p>
                    <p class="text-xs text-slate-400">"Kids gathering"</p>
                </div>
            </div>

            <div class="flex gap-2 w-full md:w-auto justify-end">
                <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-2 bg-green-100 text-green-700">
                    <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> approved
                </span>
            </div>
        </div>
    </div>
</div>
