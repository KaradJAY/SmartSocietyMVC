@{
    ViewData["Title"] = "Event Booking";
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Event Booking</h1>
            <p class="text-slate-500">
                Reserve community halls and facilities.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Booking Form -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100 h-fit">
            <h2 class="text-xl font-bold text-slate-800 mb-6">New Booking</h2>
            <form class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Select Facility</label>
                    <select class="w-full p-3 bg-slate-50 border rounded-xl" required>
                        <option value="">-- Choose --</option>
                        <option value="1">Community Hall (Capacity: 150) - ₹2000/day</option>
                        <option value="2">Swimming Pool (Capacity: 30) - ₹500/day</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Date</label>
                    <input type="date" class="w-full p-3 bg-slate-50 border rounded-xl" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-500 mb-1">No. of Days</label>
                        <input type="number" min="1" class="w-full p-3 bg-slate-50 border rounded-xl" value="1" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-500 mb-1">Est. Price</label>
                        <div class="w-full p-3 bg-slate-100 border rounded-xl text-slate-700 font-bold">
                            ₹0
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Purpose/Event Name</label>
                    <input type="text" class="w-full p-3 bg-slate-50 border rounded-xl" placeholder="Birthday Party, Meeting..." required />
                </div>

                <button type="button" class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition">
                    Request Booking
                </button>
            </form>
        </div>

        <!-- My Bookings List -->
        <div class="space-y-8 lg:col-span-2">
            <div>
                <h2 class="text-xl font-bold text-slate-800 mb-4">My Bookings</h2>
                <div class="space-y-4">
                    <!-- Pending Booking -->
                    <div class="bg-white border border-slate-100 p-5 rounded-2xl flex items-center justify-between shadow-sm">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                                <i data-lucide="calendar" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-800">
                                    Community Hall
                                </h3>
                                <p class="text-sm text-slate-500">Sun Mar 15 2026 • Birthday Party</p>
                            </div>
                        </div>

                        <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-2 bg-yellow-100 text-yellow-700">
                            <i data-lucide="clock" class="w-3.5 h-3.5"></i> pending
                        </span>
                    </div>
                    
                    <!-- Approved Booking -->
                    <div class="bg-white border border-slate-100 p-5 rounded-2xl flex items-center justify-between shadow-sm">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                                <i data-lucide="calendar" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-800">
                                    Swimming Pool
                                </h3>
                                <p class="text-sm text-slate-500">Sat Mar 21 2026 • Kids gathering</p>
                            </div>
                        </div>

                        <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-2 bg-green-100 text-green-700">
                            <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> approved
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
