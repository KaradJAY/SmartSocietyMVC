@{
    ViewData["Title"] = "My Profile";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "resident";
    var userName = User.Identity?.Name ?? "User";
}

<div class="max-w-2xl mx-auto space-y-6 animate-fade-in pb-24">
    <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
        <i data-lucide="user" class="text-blue-600"></i> My Profile
    </h2>

    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
        <div class="flex items-center gap-6 mb-8">
            <div class="relative group">
                <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center text-slate-400 overflow-hidden shadow-sm border-2 border-slate-100">
                    <i data-lucide="user" class="w-10 h-10"></i>
                </div>
                <label class="absolute inset-0 bg-black/40 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity z-10 backdrop-blur-[1px]">
                    <i data-lucide="camera" class="w-6 h-6"></i>
                    <input type="file" class="hidden" accept="image/png, image/jpeg" />
                </label>
            </div>
            <div>
                <h3 class="text-2xl font-bold text-slate-800">@userName</h3>
                <span class="px-2 py-1 rounded text-xs font-bold bg-blue-50 text-blue-600 border border-blue-100 uppercase tracking-wider mt-1 inline-block">
                    @userRole
                </span>
            </div>
        </div>

        <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Full Name</label>
                    <div class="relative">
                        <i data-lucide="user" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="name" type="text" value="@userName" class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Email Address</label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="email" type="email" value="user@example.com" class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none bg-slate-50 text-slate-500 cursor-not-allowed" disabled />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Wing</label>
                    <div class="relative">
                        <i data-lucide="map-pin" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="wing" type="text" value="A" class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Flat Number</label>
                    <div class="relative">
                        <i data-lucide="map-pin" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="flatNumber" type="text" value="101" class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-100 flex justify-end">
                <button type="button" class="bg-slate-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-800 transition flex items-center gap-2">
                    <i data-lucide="save" class="w-[18px] h-[18px]"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
