@{
    ViewData["Title"] = "Facilities Management";
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Manage Facilities</h1>
            <p class="text-slate-500">Add, update, or remove community facilities.</p>
        </div>
        <button class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
            <i data-lucide="plus" class="w-[18px] h-[18px]"></i> Add Facility
        </button>
    </div>

    <!-- List -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Facility 1 -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-4">
                <h3 class="font-bold text-lg text-slate-800">Community Hall</h3>
                <div class="flex gap-2">
                    <button class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg">
                        <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                    </button>
                    <button class="text-red-500 hover:bg-red-50 p-2 rounded-lg">
                        <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                    </button>
                </div>
            </div>
            <p class="text-sm text-slate-500 mb-4 line-clamp-2">A large hall suitable for parties, meetings, and social gatherings.</p>
            <div class="flex justify-between items-center text-sm font-medium text-slate-700">
                <span>Capacity: 150</span>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full">₹2000/day</span>
            </div>
        </div>

        <!-- Facility 2 -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-4">
                <h3 class="font-bold text-lg text-slate-800">Swimming Pool</h3>
                <div class="flex gap-2">
                    <button class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg">
                        <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                    </button>
                    <button class="text-red-500 hover:bg-red-50 p-2 rounded-lg">
                        <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                    </button>
                </div>
            </div>
            <p class="text-sm text-slate-500 mb-4 line-clamp-2">Outdoor swimming pool with changing rooms and a kid's pool area.</p>
            <div class="flex justify-between items-center text-sm font-medium text-slate-700">
                <span>Capacity: 30</span>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full">₹500/day</span>
            </div>
        </div>

        <!-- Facility 3 -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-4">
                <h3 class="font-bold text-lg text-slate-800">Gymnasium</h3>
                <div class="flex gap-2">
                    <button class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg">
                        <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                    </button>
                    <button class="text-red-500 hover:bg-red-50 p-2 rounded-lg">
                        <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                    </button>
                </div>
            </div>
            <p class="text-sm text-slate-500 mb-4 line-clamp-2">Fully equipped modern gymnasium with cardio and weight training sections.</p>
            <div class="flex justify-between items-center text-sm font-medium text-slate-700">
                <span>Capacity: 20</span>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full">₹300/day</span>
            </div>
        </div>
    </div>
</div>
